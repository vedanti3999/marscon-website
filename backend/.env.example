# =============================================
# MARSCON BACKEND - Environment Variables
# Copy this file to .env and fill in values
# =============================================

# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/marscon
# For MongoDB Atlas: mongodb+srv://<user>:<password>@cluster.mongodb.net/marscon

# Email (Nodemailer - for contact form notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=MARSCON Website <noreply@marscon.in>
EMAIL_TO=marscon.india@gmail.com

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
